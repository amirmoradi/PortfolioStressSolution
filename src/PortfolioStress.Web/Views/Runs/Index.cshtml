@model IReadOnlyList<RunListItemViewModel>
@{
    ViewData["Title"] = "Runs";
}

<div class="page-header">
    <div>
        <h1>Scenario runs</h1>
        <p class="muted">Every execution is stored with the used inputs and the results per portfolio.</p>
    </div>
    <a asp-action="Create" class="button">Create new run</a>
</div>

@if (Model.Count == 0)
{
    <div class="panel">
        <p>No stored runs.</p>
        <a asp-action="Create" class="button">First Run</a>
    </div>
}
else
{
    <div class="panel">
        <table class="table">
            <thead>
                <tr>
                    <th>Run</th>
                    <th>Started (UTC)</th>
                    <th>Policy</th>
                    <th>Inputs</th>
                    <th>Loans</th>
                    <th>Total Outstanding</th>
                    <th>Total Expected Loss</th>
                    <th>Duration</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var run in Model)
            {
                <tr>
                    <td>@run.RunId</td>
                    <td>@run.StartedUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@run.CalculationProfile</td>
                    <td>@run.CountryInputsSummary</td>
                    <td>@run.LoanCount</td>
                    <td>@run.TotalOutstandingAmount.ToString("N2")</td>
                    <td>@run.TotalExpectedLoss.ToString("N2")</td>
                    <td>@run.DurationMilliseconds ms</td>
                    <td><a asp-action="Details" asp-route-id="@run.RunId">View</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
